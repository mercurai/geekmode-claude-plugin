{
  "name": "geekmode-claude-plugin",
  "version": "0.2.0",
  "description": "Claude Code plugin for managing the geekmode-rust ticket monitoring application",
  "author": "Mercurai",
  "homepage": "https://github.com/mercurai/geekmode-claude-plugin",
  "agents": [
    "agents/reserve-ops.md",
    "agents/monitor-ops.md",
    "agents/probe-ops.md",
    "agents/tmpt-ops.md",
    "agents/proxy-ops.md",
    "agents/logs-analyst.md"
  ],
  "skills": [
    "skills/tasks/SKILL.md",
    "skills/reserves/SKILL.md",
    "skills/probe/SKILL.md",
    "skills/logs/SKILL.md",
    "skills/watch/SKILL.md",
    "skills/health/SKILL.md",
    "skills/metrics/SKILL.md"
  ],
  "commands": [],
  "hooks": [
    {"event": "SessionStart", "command": "hooks/session-start.sh"},
    {"event": "PreToolUse", "command": "hooks/pre-tool-use-destructive.sh"},
    {"event": "PostToolUse", "command": "hooks/post-tool-use-timeline.sh"},
    {"event": "Stop", "command": "hooks/stop-summary.sh"}
  ],
  "mcpServers": [
    {"name": "geekmode-rust", "command": "${PLUGIN_ROOT}/mcp/gm-mcp.exe", "args": []}
  ]
}
